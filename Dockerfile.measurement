FROM golang:1.26.1-bookworm AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/netzbremse-measurement ./cmd/measurement

FROM debian:bookworm-slim

RUN useradd --create-home --uid 10001 appuser

WORKDIR /app
COPY --from=builder /out/netzbremse-measurement /usr/local/bin/netzbremse-measurement

USER 10001:10001
EXPOSE 8081
ENTRYPOINT ["/usr/local/bin/netzbremse-measurement"]
