FROM dhi.io/golang:1.26.1-alpine3.23-dev@sha256:a6d86aa25fd494bd7f02241aa8611f14a95ce58fa22e51d4ab90891db1d7432a AS builder

ARG TARGETARCH=amd64

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY cmd/dashboard ./cmd/dashboard
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} go build -trimpath -ldflags="-s -w" -o /out/netzbremse-dashboard ./cmd/dashboard

FROM dhi.io/alpine-base:3.23@sha256:59568e54e81ee91fae451405c5a3fa911c3ba7d1cdcee2ae2a472855ef8071ca

LABEL org.opencontainers.image.source="https://github.com/sm-moshi/netzbremse" \
  org.opencontainers.image.url="https://github.com/sm-moshi/netzbremse" \
  org.opencontainers.image.title="netzbremse-dashboard" \
  org.opencontainers.image.description="Netzbremse dashboard backed by PostgreSQL instead of shared filesystem state"

WORKDIR /app
COPY --from=builder /out/netzbremse-dashboard /usr/local/bin/netzbremse-dashboard

USER nonroot
EXPOSE 8501
ENTRYPOINT ["/usr/local/bin/netzbremse-dashboard"]
